{
  "name": "picklescore",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-icons.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"npx vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "npx playwright test",
    "test:e2e:buddies": "firebase emulators:exec --only auth,firestore \"npx playwright test e2e/buddies*\"",
    "test:e2e:headed": "npx playwright test --headed",
    "emulator:start": "firebase emulators:start --only firestore",
    "build:android": "vite build && npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@solidjs/router": "^0.15.4",
    "canvas-confetti": "^1.9.4",
    "dexie": "^4.3.0",
    "firebase": "^12.9.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "lucide-solid": "^0.564.0",
    "open-simplex-noise": "^2.5.0",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.10",
    "solid-transition-group": "^0.3.0",
    "xstate": "^5.28.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "fake-indexeddb": "^6.2.5",
    "firebase-tools": "^15.6.0",
    "jsdom": "^28.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  }
}
